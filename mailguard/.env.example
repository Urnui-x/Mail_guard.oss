# MailGuard OSS Environment Variables

# Telegram Bot Configuration
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Your Telegram User ID (only this user can access the bot)
# Get your ID from @userinfobot on Telegram
TELEGRAM_ADMIN_UID=your-telegram-user-id

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Upstash Redis Configuration
# Get these from your Upstash console
REDIS_URL=redis://default:your-password@your-redis.upstash.io:6379

# Security Keys
# Generate these with: openssl rand -hex 32
JWT_SECRET=your-256-bit-hex-secret
ENCRYPTION_KEY=your-256-bit-hex-secret-64-chars

# Optional - API Service
NODE_ENV=production
PORT=3000

# Optional - Bot Service
# URL of the API service (for internal notifications)
INTERNAL_API_URL=http://localhost:3000