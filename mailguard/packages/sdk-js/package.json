{
  "name": "mailguard-sdk",
  "version": "1.0.0",
  "description": "Official JavaScript/TypeScript SDK for MailGuard OSS",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mailguard",
    "otp",
    "email",
    "verification"
  ],
  "author": "MailGuard OSS",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0"
  }
}