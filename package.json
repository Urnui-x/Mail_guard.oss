{
  "name": "mailguard",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=apps/api & npm run dev --workspace=apps/worker & npm run dev --workspace=apps/bot",
    "lint": "eslint . --ext .ts",
    "clean": "rm -rf dist node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}